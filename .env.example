# ============================================================
# VERITRACE — Variables de entorno
# ============================================================
# Copia este archivo como .env y rellena los valores reales:
#   cp .env.example .env
#
# IMPORTANTE: El archivo .env NUNCA debe subirse al repositorio.
# Ya está incluido en .gitignore.
# ============================================================

# --- Aplicación ---
APP_ENV=development          # development | production
APP_TITLE=Veritrace
APP_VERSION=2.0.0

# --- Autenticación (se activa en Fase 3) ---
# APP_USERNAME=admin
# APP_PASSWORD=cambia_esto_por_una_contraseña_segura

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0

# --- Configuración de scraping ---
# Tiempo máximo de espera por petición en segundos
SCRAPING_TIMEOUT=60
# Modo pruebas: si es true, ignora control de duplicados (útil en desarrollo)
MODO_PRUEBAS=false
